{
    "name": "drain",
    "main": "api/src/main.ts",
    "scripts": {
        "start": "cd api && bun src/main.ts",
        "prep": "cd app && bun install && bunx --bun vite build && cd ../api && bun install && cd ..",
        "initpk": "cd api && cp .env.example .env && nano .env",
        "pull": "git pull && bun prep",
        "update": "cd app && bun update && cd ../api && bun update && cd ..",
        "apidev": "cd api && DD=1 bun --watch src/main.ts",
        "appdev": "cd app && bun watch.ts",
        "appdev2": "cd app && bunx --bun vite dev"
    },
    "dependencies": {
        "@elysiajs/eden": "^1.4.6",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-context-menu": "^2.2.16",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@simplewebauthn/browser": "^13.2.2",
        "@simplewebauthn/server": "^13.2.2",
        "@tailwindcss/vite": "^4.1.18",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "elysia": "^1.4.23",
        "lucide-react": "^0.548.0",
        "mobx": "^6.15.0",
        "mobx-react-lite": "^4.1.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-router-dom": "6.27.0",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.1.18"
    },
    "devDependencies": {
        "@types/bun": "^1.3.5",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "vite": "8.0.0-beta.13"
    }
}