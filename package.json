{
    "name": "drain",
    "scripts": {
        "start": "cd api && bun src/main.ts",
        "prep": "bun install && cd app && bunx --bun vite build",
        "initpk": "cd api && cp .env.example .env && nano .env",
        "pull": "git pull && bun prep && systemctl restart drain && quik purge drain.villainsrule.xyz",
        "apidev": "cd api && DD=1 bun --watch src/main.ts",
        "appdev": "cd app && bunx --bun vite build --watch"
    },
    "dependencies": {
        "@elysiajs/eden": "^1.4.8",
        "@elysiajs/openapi": "^1.4.14",
